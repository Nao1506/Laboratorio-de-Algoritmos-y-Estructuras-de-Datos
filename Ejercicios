Ejercicio 14

using System;

class Program
{
    static void Main()
    {
        try
        {
            string frase = Console.ReadLine();

            Console.WriteLine(frase.Length);

            string[] palabras = frase.Split(' ');
            Console.WriteLine(palabras.Length);

            int vocales = 0;

            foreach (char c in frase)
            {
                if ("aeiouAEIOU".Contains(c))
                {
                    vocales++;
                }
            }

            Console.WriteLine(vocales);

            int posicion = int.Parse(Console.ReadLine());

            if (posicion < 0 || posicion >= frase.Length)
            {
                throw new IndexOutOfRangeException();
            }

            Console.WriteLine(frase[posicion]);

            int numero = int.Parse(Console.ReadLine());

            if (numero < 0)
            {
                throw new ArgumentException();
            }

            Console.WriteLine(100 / numero);
        }
        catch (FormatException)
        {
            Console.WriteLine("Error de formato");
        }
        catch (IndexOutOfRangeException)
        {
            Console.WriteLine("Posicion invalida");
        }
        catch (DivideByZeroException)
        {
            Console.WriteLine("Division por cero");
        }
        catch (ArgumentException)
        {
            Console.WriteLine("Argumento invalido");
        }
    }
}
