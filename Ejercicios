using System;

class Program
{
    static void Main()
    {
        string frase;

        do
        {
            Console.Write("Frase: ");
            frase = Console.ReadLine();

            if (frase != "agusfortnite2008")
            {
                Console.WriteLine(Reemplazar(frase, 'a'));
                Console.WriteLine(Reemplazar(frase, 'e'));
                Console.WriteLine(Reemplazar(frase, 'i'));
                Console.WriteLine(Reemplazar(frase, 'o'));
                Console.WriteLine(Reemplazar(frase, 'u'));
            }

        } while (frase != "agusfortnite2008");
    }

    static string Reemplazar(string texto, char vocal)
    {
        string resultado = "";

        foreach (char c in texto)
        {
            if ("aeiouAEIOU".Contains(c))
                resultado += vocal;
            else
                resultado += c;
        }

        return resultado;
    }
}
